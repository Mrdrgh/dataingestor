APP_PORT=3001

AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_DAG_ID=ingest_postgres_to_delta
AIRFLOW_AUTH_TYPE=basic
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_TIMEOUT_MS=10000
AIRFLOW_DAGS_DIR=../airflow/dags

PGHOST=6.tcp.eu.ngrok.io
PGPORT=29555
PGDATABASE=fusion_forge_db
PGUSER=postgres
PGPASSWORD=DevPassword123!

PIPELINES_FILE=./data/pipelines.json
PREVIEW_ROW_LIMIT=20
DELTA_BASE_PATH=s3a://fusion-delta
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=fusion-delta
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MINIO_PATH_STYLE=true

# Notebooks Database (postgres-notebooks in docker-compose)
NB_PGHOST=localhost
NB_PGPORT=5434
NB_PGDATABASE=notebooks_db
NB_PGUSER=notebooks
NB_PGPASSWORD=notebooks
